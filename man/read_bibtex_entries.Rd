% Generated by hand to match the package helper
\name{read_bibtex_entries}
\alias{read_bibtex_entries}
\title{Read BibTeX entries as canonical reference ids}
\usage{
read_bibtex_entries(path, config = NULL, prefer_linked_arxiv = TRUE)
}
\arguments{
\item{path}{Path to a BibTeX \code{.bib} file.}

\item{config}{Optional parsed config list or a direct config path. When
omitted, \code{litxr} reads \code{LITXR_DATA_ROOT}.}

\item{prefer_linked_arxiv}{If \code{TRUE} (default), DOI values are promoted to
a linked arXiv ref_id when the identity map contains a matching DOI→arXiv
pair. If \code{FALSE}, DOI values are returned as DOI ref_ids.}
}
\value{
Character vector of canonical reference ids in file order.
}
\description{
Reads a BibTeX file entry by entry and returns the canonical \code{ref_id}
values recognized from each entry, using this priority:
arXiv first, then DOI, then ISBN. Entries without a recognizable id are
skipped.
}
\details{
Recognized ids are normalized as follows:
\itemize{
\item arXiv ids become \code{arxiv:<id>}
\item DOI values become \code{doi:<doi>}
\item ISBN values become \code{isbn:<isbn>}
}
}
